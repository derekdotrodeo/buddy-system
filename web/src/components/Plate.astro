---
// The brand mark *is* a silkscreen label: a two-cell boxed plate, first cell filled.
// "Labels are the logo" (P2). Used for the wordmark, section numbers, and step markers.
interface Props {
  fill: string; // first cell (filled / knockout text)
  rest: string; // second cell (outlined)
  tone?: 'on-paper' | 'on-ink'; // which surface it sits on
  size?: 'sm' | 'md' | 'lg';
}
const { fill, rest, tone = 'on-paper', size = 'md' } = Astro.props;
---
<span class:list={['plate', `plate--${tone}`, `plate--${size}`]}>
  <span class="plate__cell plate__cell--fill">{fill}</span>
  <span class="plate__cell">{rest}</span>
</span>

<style>
  .plate {
    --line: var(--ink);
    --surface: var(--paper);
    display: inline-flex;
    font-family: var(--font-cond);
    font-weight: 800;
    letter-spacing: 0.04em;
    line-height: 1;
    border-radius: var(--r-sm);
    overflow: hidden;
    white-space: nowrap;
  }
  /* on dark surfaces the lines go white and the knockout shows the ink behind */
  .plate--on-ink { --line: var(--silk); --surface: var(--ink); }

  .plate__cell {
    display: inline-flex;
    align-items: center;
    border: var(--bw) solid var(--line);
    color: var(--line);
  }
  .plate__cell--fill {
    background: var(--line);
    color: var(--surface); /* knockout text */
    border-right: 0;
  }

  .plate--sm .plate__cell { padding: 2px 6px; font-size: 0.7rem; }
  .plate--md .plate__cell { padding: 3px 9px; font-size: 0.95rem; }
  .plate--lg .plate__cell { padding: 6px 15px; font-size: clamp(1.2rem, 3vw, 1.8rem); }
</style>
